{
  "agents": {
    "defaults": {
      "provider": "openai",
      "model": "openai/gpt-4o-mini"
    }
  },
  "providers": {
    "openai": {
      "apiKey": "YOUR_OPENROUTER_KEY_HERE",
      "apiBase": "https://openrouter.ai/api/v1"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://backend:8000",
          "NANOBOT_LMS_API_KEY": "lms-secret-key-123"
        }
      }
    }
  }
}
